import pandas as pd

# Create Customer DataFrame
data = {
    "Customer ID": [101, 102, 103, 104, 105, 106, 107],
    "Customer Name": ["John", "Alice", "David", "Emma", "Michael", "Sophia", "James"],
    "City": ["New York", "London", "Paris", "Tokyo", "Dubai", "Delhi", "Sydney"]
}

df = pd.DataFrame(data)

# Save as CSV and Excel
df.to_csv("customers.csv", index=False)
df.to_excel("customers.xlsx", index=False)

# 1. Read the CSV file
csv_df = pd.read_csv("customers.csv")
print("1. CSV File:")
print(csv_df)

# 2. Read the Excel file
excel_df = pd.read_excel("customers.xlsx")
print("\n2. Excel File:")
print(excel_df)

# 3. Display the complete DataFrame
print("\n3. Complete DataFrame:")
print(csv_df)

# 4. Display the first 5 rows
print("\n4. First 5 Rows:")
print(csv_df.head())

# 5. Display the last 5 rows
print("\n5. Last 5 Rows:")
print(csv_df.tail())

# 6. Display the last 2 rows
print("\n6. Last 2 Rows:")
print(csv_df.tail(2))

# 7. Display the information of the DataFrame
print("\n7. DataFrame Information:")
csv_df.info()

# 8. Display the statistical summary
print("\n8. Statistical Summary:")
print(csv_df.describe(include="all"))
